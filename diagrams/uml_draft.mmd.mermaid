classDiagram
    direction LR

    class Task {
        +str description
        +int duration_minutes
        +str frequency
        +Optional~time~ scheduled_time
        +bool completed
        +mark_complete() void
        +mark_incomplete() void
        +is_complete() bool
    }

    class Pet {
        +str name
        +str species
        +str breed
        +List~Task~ tasks
        +add_task(task Task) void
        +remove_task(task Task) void
        +get_tasks() List~Task~
    }

    class Owner {
        +str name
        +List~Pet~ pets
        +add_pet(pet Pet) void
        +remove_pet(pet Pet) void
        +get_pets() List~Pet~
        +all_tasks() List~Task~
    }

    class Scheduler {
        +Owner owner
        +get_all_tasks() List~Task~
        +get_pending_tasks() List~Task~
        +get_completed_tasks() List~Task~
        +organize_tasks_by_pet() Dict~str, List~Task~~
        +organize_tasks_by_frequency() Dict~str, List~Task~~
        +sort_tasks_by_time() List~Task~
        +mark_task_complete(task Task) void
    }

    Owner "1" *-- "0..*" Pet : owns
    Pet "1" *-- "0..*" Task : has
    Scheduler --> Owner : manages
